{% extends 'base.html.twig' %}

{% block title %}Procedure{% endblock %}

{% block body %}
    <h1>Procedure</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ procedure.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ procedure.nom }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ procedure.description }}</td>
            </tr>
            <tr>
                <th>Document</th>
                <td>{{ procedure.document }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_procedure_index') }}">back to list</a>

    <a href="{{ path('app_procedure_edit', {'id': procedure.id}) }}">edit</a>

    {{ include('procedure/_delete_form.html.twig') }}
{% endblock %}
