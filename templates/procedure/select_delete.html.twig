{% extends 'base.html.twig' %}

{% block stylesheets %}
	<style>
		body {
			background-image: url('/images/bg-circuit.jpg');
			background-size: cover;
			background-repeat: no-repeat;
			font-family: Arial, sans-serif;
		}

		.app-container {
			background-color: rgba(255, 255, 255, 0.95);
			max-width: 1000px;
			margin: 60px auto;
			padding: 30px;
			border-radius: 20px;
		}

		h1 {
			text-align: center;
			font-size: 40px;
			font-style: italic;
			margin-bottom: 10px;
		}

		p {
			text-align: center;
			margin-bottom: 30px;
		}

		table {
			width: 100%;
			border-collapse: collapse;
		}

		th,
		td {
			padding: 15px;
			text-align: center;
		}

		th {
			border-bottom: 2px solid #ccc;
		}

		td {
			border-bottom: 1px solid #eee;
		}
	</style>
{% endblock %}

{% block body %}
	<div class="app-container">
		<h1>
			Supprimer une procédure
		</h1>
		<p>
			Sélectionnez une procédure à supprimer.
		</p>

		<table>
			<thead>
				<tr>
					<th>
						Procédure
					</th>
					<th>
						Descriptions
					</th>
					<th>
						Action
					</th>
				</tr>
			</thead>
			<tbody>
                {% for procedure in procedures %}
					<tr>
						<td>
							{{ procedure.nom }}
						</td>
						<td>
							{{ procedure.description }}
						</td>
						<td>
                            <form method="post" action="{{ path('app_procedure_delete', { id: procedure.id }) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer cette procédure ?');">
								<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ procedure.id) }}">
								<button class="btn btn-danger">
									🗑️ Supprimer
								</button>
							</form>
						</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>

		<a href="{{ path('app_procedure_index') }}" class="btn btn-secondary">
			↩ Retour
		</a>
	</div>
{% endblock %}
