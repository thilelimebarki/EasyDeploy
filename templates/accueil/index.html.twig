{% extends 'base.html.twig' %}

{% block title %}Accueil - EasyDeploy{% endblock %}

{% block body %}

<div style="background-color: #f0f0f0; padding: 2rem; text-align: center;">
    <h1 style="font-style: italic; text-decoration: underline;">Welcome to EasyDeploy</h1>
</div>

<div style="background-color: #1e1e2f; color: white; padding: 4rem; text-align: center;">
