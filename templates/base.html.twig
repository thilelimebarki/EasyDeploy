<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}EasyDeploy{% endblock %}</title>
        {% block stylesheets %}{% endblock %}
        <style>
            body {
                margin: 0;
                padding: 0;
                min-height: 100vh;
                position: relative;
                font-family: sans-serif;
            }

            .background {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background-image: url('{{ asset('images/font.jpg') }}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                opacity: 0.8; /* Opacité ici */
                z-index: -1;
            }

            .content {
                position: relative;
                z-index: 1;
            }
        </style>
    </head>
    <body>
        <div class="background"></div>

        <div class="content">
            {% block body %}{% endblock %}
        </div>
    </body>
</html>


