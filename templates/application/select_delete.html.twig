{% extends 'base.html.twig' %}

{% block stylesheets %}
	<style>

		.app-container {
			background-color: rgba(255, 255, 255, 0.95);
			max-width: 1000px;
			margin: 60px auto;
			padding: 30px;
			border-radius: 20px;
		}

		h1 {
			text-align: center;
			font-size: 40px;
			font-style: italic;
			margin-bottom: 10px;
		}

		p {
			font-size: 1.1rem;
			text-align: center;
			margin-bottom: 30px;
		}

		table {
			width: 100%;
			border-collapse: collapse;
		}

		th,
		td {
			font-size: 1.1rem;
			padding: 15px;
			text-align: center;
		}

		th {
			border-bottom: 2px solid #ccc;
		}

		td {
			border-bottom: 1px solid #eee;
		}
		.btn-cancel {
			background: #9E9E9E;
			color: black;
			display: inline-block;
			padding: 10px 18px;
			border-radius: 6px;
			font-size: 1.1rem;
			text-decoration: none;
			transition: background 0.3s, transform 0.2s;
		}

		.btn-cancel:hover {
			background: #5a6268;
			transform: scale(1.05);
		}

		.btn-delete {
			font-size: 1.1rem;
			background-color: #841b1bff;
			padding: 8px 12px;
			border: none;
			border-radius: 5px;
			text-decoration: none;
			color: white;
			cursor: pointer;
			margin: 5px;
			display: inline-block;
		}

		.btn-delete:hover {
			background: #5a1212ff;
			transform: scale(1.05);
		}
		.table-container {
			max-height: 400px; /* hauteur visible */
			overflow-y: auto; /* barre de défilement verticale */
			border-radius: 10px;
		}
	</style>
{% endblock %}

{% block body %}
	<div class="app-container">
		<h1>
			Supprimer une application
		</h1>
		<p>
			Sélectionnez une application à supprimer.
		</p>

		<div class="table-container">
			<table>
				<thead>
					<tr>
						<th>
							Applications
						</th>
						<th>
							Descriptions
						</th>
						<th>
							Action
						</th>
					</tr>
				</thead>
				<tbody>
					{% for application in applications %}
						<tr>
							<td>
								{{ application.nomApplication }}
							</td>
							<td>
								{{ application.description }}
							</td>
							<td>
								<form method="post" action="{{ path('app_application_delete', { id: application.id }) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer cette application ?');">
									<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ application.id) }}">
									<button class="btn btn-delete">
										🗑️ Supprimer
									</button>
								</form>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>

		<a href="{{ path('app_application_index') }}" class="btn btn-cancel">
			Retour
		</a>
		<a href="{{ path('dashboard') }}" class="btn btn-cancel">
			Accueil
		</a>
	</div>
{% endblock %}
