{% extends 'base.html.twig' %}

{% block title %}Modifier l'application{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1 class="mb-4">Modifier l'application</h1>

    {{ form_start(form) }}
        <div class="mb-3">
            {{ form_label(form.nomApplication, 'Nom de l\'application') }}
            {{ form_widget(form.nomApplication, {'attr': {'class': 'form-control'}}) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.description, 'Description') }}
            {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.scriptPath, 'Nom du script (.ps1)') }}
            {{ form_widget(form.scriptPath, {'attr': {'class': 'form-control'}}) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.commandeExecution, 'Commande à exécuter') }}
            {{ form_widget(form.commandeExecution, {'attr': {'class': 'form-control'}}) }}
        </div>

        <button class="btn btn-primary">💾 Enregistrer les modifications</button>
        <a href="{{ path('app_application_index') }}" class="btn btn-secondary">↩ Retour</a>
    {{ form_end(form) }}
</div>
{% endblock %}
